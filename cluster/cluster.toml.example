# Gravity Cluster Configuration
# Copy this file to cluster.toml and modify as needed
# Used for node deployment (make init, make deploy, make start)

[cluster]
name = "gravity-devnet"
base_dir = "/tmp/gravity-cluster"
# data_base_dir = "/tmp/gravity-cluster-data"  # optional: data storage root (default: base_dir)
# log_dir = "/tmp/gravity-cluster-logs"  # optional: log storage root (default: data_base_dir or base_dir)

# Genesis data source
# Default paths point to locally generated genesis (from make genesis)
# Modify these to join an existing network
[genesis_source]
genesis_path = "./output/genesis.json"
waypoint_path = "./output/waypoint.txt"

# External dependencies
[dependencies.gravity_bench]
repo = "https://github.com/Galxe/gravity_bench.git"
ref = "main"

# Cluster-level RPC settings (optional)
# Defaults keep RPC local-only and expose only public APIs. Override deliberately
# for public full nodes and prefer firewalls or a reverse proxy when exposing RPC.
# ws_* values are consumed only by nodes that opt in via per-node `ws_port`.
[rpc]
http_addr       = "127.0.0.1"
http_corsdomain = ""
http_api        = "eth,net,web3,rpc"
ws_addr         = "127.0.0.1"
ws_origins      = ""
ws_api          = "eth,net,web3,rpc"

# Node definitions
# Role types:
#   - "genesis": Genesis validator (must match genesis.toml)
#   - "validator": Validator node not in genesis (can join later via on-chain txn)
#   - "vfn": Full node, uses onchain discovery to sync;
#            set `ws_port` on a VFN to enable WebSocket RPC (default: WS off)
#   - "pfn": Public Full Node, reaches upstream via static `seeds` on Public network
#
# Role → port schema (deploy.sh enforces; see _local/drafts/cluster-seeds/usage.md §9):
#   genesis/validator: validator_port (required, Validator net) + vfn_port (required, Vfn listener).
#                      Must NOT set public_port.
#   vfn:               vfn_port (required) + public_port (optional, seed-accept-only listener
#                      for downstream PFNs). Must NOT set validator_port.
#   pfn:               public_port (required, Public listener). Must NOT set validator_port or vfn_port.
#
# Deprecated alias: `p2p_port` is accepted as a synonym for `validator_port` (warns once on deploy).
#
# Per-node source (required, like Cargo.toml):
#   source = { project_path = "../" }                                  # local project, cargo build
#   source = { bin_path = "/opt/gravity/v2.1/gravity_node" }           # pre-built binary
#   source = { github = "Galxe/gravity-sdk", rev = "v2.0.0" }         # clone + build
#
# Per-node identity (optional, defaults to local file).
# `make init` always writes a public-only sidecar (output/<id>/config/
# identity.public.yaml) for `make genesis` to consume; the private blob
# is materialized differently per source:
#
#   identity = { source = "file" }
#     Default. `make init` writes identity.yaml under output/<id>/config/;
#     `make deploy` copies it to <data_dir>/config/identity.yaml.
#
#   identity = { source = "gcp_secret", secret = "projects/<P>/secrets/<S>/versions/latest" }
#     `make init` generates the keypair entirely in memory and pushes it
#     to Secret Manager via reqwest; identity.yaml is never written to
#     disk. `make deploy` leaves the runtime config dir without
#     identity.yaml; gravity_node fetches the IdentityBlob from Secret
#     Manager at startup. The binary MUST be built with
#     `--features gcp-secret-manager` (forward via gravity_node/gaptos).
#     Auth (init-time, on operator workstation):
#       export GCP_ACCESS_TOKEN=$(gcloud auth print-access-token)
#     Auth (runtime): GCE metadata server (bound SA with
#     roles/secretmanager.secretAccessor), or GCP_ACCESS_TOKEN env var.
#     Pin a specific version (e.g. versions/3) instead of versions/latest
#     so rotation requires an explicit cluster.toml change rather than a
#     restart side-effect.

# ============ Genesis Nodes (node1-node4) ============

[[nodes]]
id = "node1"
role = "genesis"
source = { project_path = "../" }
host = "127.0.0.1"
validator_port = 6180
vfn_port = 6190
rpc_port = 8545
metrics_port = 9001
inspection_port = 10000
https_port = 1024
authrpc_port = 8551
reth_p2p_port = 12024

[[nodes]]
id = "node2"
role = "genesis"
source = { project_path = "../" }
host = "127.0.0.1"
validator_port = 6181
vfn_port = 6191
rpc_port = 8546
metrics_port = 9002
inspection_port = 10001
https_port = 1025
authrpc_port = 8552
reth_p2p_port = 12025

[[nodes]]
id = "node3"
role = "genesis"
source = { project_path = "../" }
host = "127.0.0.1"
validator_port = 6182
vfn_port = 6192
rpc_port = 8547
metrics_port = 9003
inspection_port = 10002
https_port = 1026
authrpc_port = 8553
reth_p2p_port = 12026

[[nodes]]
id = "node4"
role = "genesis"
source = { project_path = "../" }
host = "127.0.0.1"
validator_port = 6183
vfn_port = 6193
rpc_port = 8548
metrics_port = 9004
inspection_port = 10003
https_port = 1027
authrpc_port = 8554
reth_p2p_port = 12027

# ============ Validator Nodes (node5) ============

[[nodes]]
id = "node5"
host = "127.0.0.1"
role = "validator"
source = { project_path = "../" }
validator_port = 6184
vfn_port = 6194
rpc_port = 8549
metrics_port = 9005
inspection_port = 10004
https_port = 1028
authrpc_port = 8565
reth_p2p_port = 12028

# ============ Full Nodes (vfn1) ============

[[nodes]]
id = "vfn1"
host = "127.0.0.1"
role = "vfn"
source = { project_path = "../" }
# identity = { source = "gcp_secret", secret = "projects/my-proj/secrets/vfn1-identity/versions/latest" }
vfn_port = 6195
rpc_port = 8550
# ws_port = 8650   # uncomment to enable WebSocket RPC on this VFN (validators don't expose WS)
metrics_port = 9006
inspection_port = 10005
https_port = 1029
authrpc_port = 8566
reth_p2p_port = 12029

# Relayer configuration
[relayer]
relayer_rpc_url = "https://sepolia.drpc.org"

[faucet_init]
num_accounts = 0 # Set to > 0 to enable auto-initialization
private_key = "0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
eth_balance = "1000000000000000000"

# ============ Optional: VFN shadow topology ============
# Register an independent VFN as a validator's on-chain `fullnode_address`.
# The VFN dials its validator via a static seed on the Vfn network (not onchain
# discovery, which would round-trip back to the VFN itself). See
# _local/drafts/vfn-shadow/design.md §1.2 and _local/drafts/cluster-seeds/usage.md §6.1.
#
# [[nodes]]
# id = "vfn-alpha"
# role = "vfn"
# seeds = [
#     { from = "node1" },             # Vfn seeds -> node1's vfn_port; role auto-inferred = Validator
# ]
# source = { project_path = "../" }
# host = "mgmt.vfn-alpha.example.com" # control-plane RPC (status.sh / pytest / faucet.sh)
# internal_host = "10.0.1.20"         # optional: intra-cluster p2p peer dial; falls back to host
# vfn_port = 6193                     # listener; on-chain fullnode_address points here
# rpc_port = 8546
# metrics_port = 9100
# inspection_port = 10100
# https_port = 1100
# authrpc_port = 8600
# reth_p2p_port = 12100

# ============ Optional: PFN (Public Full Node) ============
# PFN listens only on the Public network and syncs from upstream VFN/PFN via
# static seeds. Does not enter genesis, does not participate in consensus,
# and does not write an on-chain fullnode_address. See
# _local/drafts/cluster-seeds/usage.md §6.2.
#
# [[nodes]]
# id = "pfn-edge-1"
# role = "pfn"
# source = { project_path = "../" }
# host = "edge1.example.com"
# public_port = 6284                  # Public listener (upstream-dial + peer-accept)
# seeds = [
#     { from = "vfn-alpha" },         # dial vfn-alpha's public_port; role auto-inferred = ValidatorFullNode
#     # Multiple upstreams are fine:
#     # { from = "vfn-beta" },
#     # External seed (cluster-external peer):
#     # { peer_id    = "0xdeadbeef...",
#     #   host       = "seed.public.gravity.xyz",
#     #   port       = 6180,
#     #   network_pk = "0xabc...",
#     #   role       = "PreferredUpstream" },
# ]
# rpc_port = 18548
# metrics_port = 9200
# inspection_port = 10200
# https_port = 1200
# authrpc_port = 8700
# reth_p2p_port = 12200
